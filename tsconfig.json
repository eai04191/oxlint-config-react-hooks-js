{
    "extends": "@tsconfig/strictest/tsconfig.json",
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": ["node"],
        "erasableSyntaxOnly": true,
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "declaration": false,
        "noEmit": true
    },
    "include": ["scripts", "tests"]
}
